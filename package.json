{
    "name": "ralph-telegram-bot",
    "version": "1.0.0",
    "description": "Telegram bot for running Ralph autonomous agent loops",
    "packageManager": "yarn@4.12.0",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "build": "yarn workspace ralph build",
        "start": "yarn workspace ralph start",
        "service:install": "sudo cp ralph.service /etc/systemd/system/ralph.service && sudo systemctl daemon-reload && sudo systemctl enable ralph",
        "service:start": "sudo systemctl start ralph",
        "service:stop": "sudo systemctl stop ralph",
        "service:restart": "sudo systemctl restart ralph",
        "service:status": "sudo systemctl status ralph",
        "service:logs": "sudo journalctl -u ralph -f"
    },
    "workspaces": [
        "packages/*"
    ],
    "devDependencies": {
        "typescript": "^5.9.3"
    }
}
