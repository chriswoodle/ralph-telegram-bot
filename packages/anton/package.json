{
  "name": "anton",
  "version": "0.0.1",
  "private": true,
  "description": "Self-hosted orchestration tool for Ralph agent automation",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A run build",
    "typecheck": "yarn workspaces foreach -A run typecheck",
    "test": "yarn workspaces foreach -A run test",
    "lint": "yarn workspaces foreach -A run lint",
    "dev:backend": "yarn workspace @anton/backend dev",
    "dev:frontend": "yarn workspace @anton/frontend dev"
  }
}
