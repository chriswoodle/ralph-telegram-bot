  "info": {
    "title": "Anton API",
    "description": "Anton orchestration tool API",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "CreateProjectDto": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "displayName",
          "description"
        ]
      },
      "SubmitInputDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "assets": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fileName": {
                  "type": "string"
                },
                "filePath": {
                  "type": "string"
                },
                "mimeType": {
                  "type": "string"
                }
              },
              "required": [
                "fileName",
                "filePath"
              ]
            }
          }
        },
        "required": [
          "text"
        ]
      },
      "AnswerQuestionsDto": {
        "type": "object",
        "properties": {
          "answers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "question": {
                  "type": "string"
                },
                "answer": {
                  "type": "string"
                }
              },
              "required": [
                "question",
                "answer"
              ]
            }
          }
        },
        "required": [
          "answers"
        ]
      },
      "ModifyPrdDto": {
        "type": "object",
        "properties": {
          "modificationRequest": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "modificationRequest"
        ]
      },
      "UploadAssetDto": {
        "type": "object",
        "properties": {
          "fileName": {
            "type": "string",
            "minLength": 1
          },
          "fileBase64": {
            "type": "string",
            "minLength": 1
          },
          "mimeType": {
            "type": "string"
          }
        },
        "required": [
          "fileName",
          "fileBase64"
        ]
      },
      "GenerateTasksDto": {
        "type": "object",
        "properties": {
          "prdId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          }
        },
        "required": [
          "prdId"
        ]
      },
      "EditStoryDto": {
        "type": "object",
        "properties": {
          "editPrompt": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "editPrompt"
        ]
      },
      "ReorderStoriesDto": {
        "type": "object",
        "properties": {
          "storyIds": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "storyIds"
        ]
      },
      "ConfigureExecutionDto": {
        "type": "object",
        "properties": {
          "taskSetId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          },
          "parallelCount": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          }
        },
        "required": [
          "taskSetId",
          "parallelCount"
        ]
      },
      "PickWinnerDto": {
        "type": "object",
        "properties": {
          "worktreeId": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "worktreeId"
        ]
      }
    }
  }
}