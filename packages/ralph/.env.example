# General
PORT=4000

# Service Host
SERVICE_HOST=http://localhost:4000

# Generate Spec
GENERATE_SPEC=false

# Build ID
BUILD_ID=1234567890

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Bot display name (shown in Telegram messages)
# BOT_NAME=Ralph

# Base directory where Ralph projects will be created
RALPH_PROJECTS_DIR=./projects

# Allowed Telegram user IDs (comma-separated) — leave empty to allow all
ALLOWED_USERS=

# OpenRouter API Key
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenRouter model ID (default: minimax/minimax-m2.5)
# OPENROUTER_MODEL=minimax/minimax-m2.5